{
  "name": "@svg-to-video/web",
  "version": "0.17.0",
  "description": "Professional CSS-animated SVG to Video (MP4, WebM, MKV, MOV) and Animated Image (aPNG, GIF) Studio: frame-accurate rendering, alpha-channel transparency, and serverless WebCodecs.",
  "author": "GehDoc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GehDoc/svg-to-video.git",
    "directory": "web"
  },
  "bugs": {
    "url": "https://github.com/GehDoc/svg-to-video/issues"
  },
  "homepage": "https://github.com/GehDoc/svg-to-video#readme",
  "funding": {
    "url": "https://github.com/GehDoc/svg-to-video/?sponsor=1"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test:demo": "GENERATE_DEMO=true playwright test tests/demo.spec.ts",
    "test:web": "playwright test --reporter=list",
    "test:unit": "vitest run",
    "test:storybook": "test-storybook",
    "test:visual": "vitest run -c vitest.visual.config.ts",
    "test:visual:update": "vitest run -c vitest.visual.config.ts -u",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o dist/storybook"
  },
  "dependencies": {
    "coi-serviceworker": "^0.1.7",
    "gifenc": "^1.0.3",
    "mediabunny": "^1.39.2",
    "next": "^16.2.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@storybook/test-runner": "^0.24.3",
    "@svgr/webpack": "^8.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/gif.js": "^0.2.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/umami": "^2.10.1",
    "@types/upng-js": "^2.1.5",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "axe-playwright": "^2.2.2",
    "driver.js": "^1.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.58.2",
    "sass": "^1.99.0",
    "storybook": "^10.3.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "upng-js": "^2.1.0",
    "vite": "^8.0.5",
    "vite-plugin-sitemap": "^0.8.2",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.1"
  }
}
