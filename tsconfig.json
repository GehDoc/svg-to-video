{
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "shared/**/*.ts", "tests/**/*.ts"]
}
