{
  "name": "svg-to-video",
  "version": "0.11.1",
  "type": "module",
  "description": "Professional animated SVG to MP4/WebM/MKV/MOV converter featuring frame-accurate rendering, CLI automation, and a serverless Web Studio.",
  "author": "GehDoc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GehDoc/svg-to-video.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "animation",
    "css",
    "video",
    "svg",
    "convert",
    "mp4",
    "webm",
    "transparency",
    "alpha-channel",
    "web-animations-api"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "jsdom": "^29.1.1",
    "puppeteer": "^24.38.0",
    "tsx": "^4.22.0"
  },
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/ffprobe-static": "^2.0.3",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.4.0",
    "@types/pngjs": "^6.0.5",
    "@types/puppeteer": "^5.4.7",
    "eslint": "^8.0.0",
    "ffprobe": "^1.1.2",
    "ffprobe-static": "^3.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-sh": "^0.18.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.3"
  },
  "scripts": {
    "lint": "eslint . --ext .js,.mjs,.ts,.tsx && npm run lint -w web",
    "lint:fix": "eslint . --fix && npm run lint:fix -w web",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test:cli": "tsx --test tests/cli.spec.ts",
    "test:unit": "tsx --test src/**/*.test.ts && vitest run shared/*.test.ts && npm run test:unit -w web",
    "test:web": "npm run test:web -w web",
    "test:storybook": "npm run test:storybook -w web",
    "test:visual": "npm run test:visual -w web",
    "test:visual:update": "npm run test:visual:update -w web",
    "test": "npm run test:cli && npm run test:web && npm run test:unit && npm run test:storybook && npm run test:visual",
    "storybook": "npm run storybook -w web",
    "type-check": "tsc -p tsconfig.json --noEmit && npm run type-check -w web",
    "check": "npm run lint && npm run format && npm run type-check && npm run test",
    "check:fast": "npm run lint && npm run format && npm run type-check",
    "fix": "npm run lint:fix && npm run format:fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,mjs,ts,tsx,json,md,yml,html,Dockerfile,dockerfile,css,scss}": "prettier --write",
    "src/**/*.ts": "eslint --fix",
    "shared/**/*.ts": "eslint --fix",
    "tests/**/*.ts": "eslint --fix",
    "web/**/*.{ts,tsx,js}": "npm run lint --workspace=web --fix"
  },
  "main": "src/index.ts",
  "bin": {
    "svg-to-video": "src/index.ts"
  },
  "workspaces": [
    "web"
  ],
  "overrides": {
    "vitest": "4.1.4",
    "@vitest/spy": "4.1.4",
    "@vitest/expect": "4.1.4",
    "@vitest/utils": "4.1.4",
    "@vitest/mocker": "4.1.4",
    "@vitest/runner": "4.1.4",
    "@vitest/snapshot": "4.1.4"
  }
}
