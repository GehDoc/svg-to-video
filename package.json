{
  "name": "svg-to-video",
  "version": "0.1",
  "description": "Command-line tool for converting a CSS-animated SVG to a MP4 video",
  "author": "GehDoc",
  "keywords": [
    "animation",
    "css",
    "video",
    "svg",
    "convert",
    "mp4"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "puppeteer": "^24.38.0"
  },
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/node": "^25.4.0",
    "@types/puppeteer": "^5.4.7",
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-sh": "^0.18.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test:e2e": "node --test tests/e2e.test.mjs",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "check": "npm run lint && npm run format && npm run type-check && npm run test:e2e",
    "check:fast": "npm run lint && npm run format && npm run type-check",
    "fix": "npm run lint:fix && npm run format:fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,mjs,ts,json,md,yml,Dockerfile,dockerfile}": "prettier --write",
    "**/*.{js,mjs,ts}": [
      "eslint --fix"
    ]
  },
  "main": "src/index.js",
  "bin": {
    "svg-to-video": "src/index.js"
  }
}
