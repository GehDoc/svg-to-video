{
  "name": "svg-to-video",
  "version": "0.19.0",
  "type": "module",
  "description": "Professional animated SVG to Video (MP4/WebM/MKV/MOV) and Animated Image (aPNG/GIF) converter featuring frame-accurate rendering, CLI automation, and a serverless Web Studio.",
  "author": "GehDoc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GehDoc/svg-to-video.git"
  },
  "bugs": {
    "url": "https://github.com/GehDoc/svg-to-video/issues"
  },
  "homepage": "https://github.com/GehDoc/svg-to-video#readme",
  "funding": {
    "url": "https://github.com/GehDoc/svg-to-video/?sponsor=1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "animation",
    "css",
    "video",
    "svg",
    "convert",
    "mp4",
    "webm",
    "apng",
    "gif",
    "gifenc",
    "transparency",
    "alpha-channel",
    "web-animations-api"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "jsdom": "^29.1.1",
    "puppeteer": "^24.38.0",
    "tsx": "^4.22.0"
  },
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/ffprobe-static": "^2.0.3",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.4.0",
    "@types/pngjs": "^6.0.5",
    "@types/puppeteer": "^5.4.7",
    "eslint": "^8.0.0",
    "ffprobe": "^1.1.2",
    "ffprobe-static": "^3.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-sh": "^0.18.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "4.1.8",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8"
  },
  "scripts": {
    "lint": "eslint . && npm run lint -w web",
    "lint:fix": "eslint . --fix && npm run lint:fix -w web",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test:cli": "tsx --test tests/cli.spec.ts",
    "test:unit": "tsx --test src/**/*.test.ts && vitest run shared/*.test.ts && npm run test:unit -w web",
    "test": "npm run test:cli && npm run test:unit && npm run test:web -w web && npm run test:storybook -w web && npm run test:visual -w web",
    "type-check": "tsc -p tsconfig.json --noEmit && npm run type-check -w web",
    "check": "npm run lint && npm run format && npm run type-check && npm run test",
    "check:fast": "npm run lint && npm run format && npm run type-check",
    "fix": "npm run lint:fix && npm run format:fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,mjs,ts,tsx,json,md,yml,html,Dockerfile,dockerfile,css,scss}": "prettier --write",
    "src/**/*.ts": "eslint --fix",
    "shared/**/*.ts": "eslint --fix",
    "tests/**/*.ts": "eslint --fix",
    "web/**/*.{ts,tsx,js}": "npm run lint --workspace=web -- --fix"
  },
  "main": "src/index.ts",
  "bin": {
    "svg-to-video": "src/index.ts"
  },
  "workspaces": [
    "web"
  ],
  "overrides": {
    "vitest": "$vitest",
    "@vitest/spy": "$vitest",
    "@vitest/expect": "$vitest",
    "@vitest/utils": "$vitest",
    "@vitest/mocker": "$vitest",
    "@vitest/runner": "$vitest",
    "@vitest/snapshot": "$vitest"
  }
}
