{
  "name": "svg-to-video",
  "version": "0.3.0",
  "description": "Command-line tool for converting a CSS-animated SVG to a MP4 video",
  "author": "GehDoc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GehDoc/svg-to-video.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "animation",
    "css",
    "video",
    "svg",
    "convert",
    "mp4"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "puppeteer": "^24.38.0"
  },
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/node": "^25.4.0",
    "@types/puppeteer": "^5.4.7",
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-sh": "^0.18.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "lint": "eslint . && npm run lint -w web",
    "lint:fix": "eslint . --fix && npm run lint:fix -w web",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test:cli": "node --test tests/e2e.test.mjs",
    "test:web": "npm run test -w web",
    "test:storybook": "npm run test:storybook -w web",
    "test:visual": "npm run test:visual -w web",
    "test:visual:update": "npm run test:visual:update -w web",
    "test": "npm run test:cli && npm run test:web && npm run test:storybook && npm run test:visual",
    "storybook": "npm run storybook -w web",
    "type-check": "tsc -p tsconfig.json --noEmit && npm run type-check -w web",
    "check": "npm run lint && npm run format && npm run type-check && npm run test",
    "check:fast": "npm run lint && npm run format && npm run type-check",
    "fix": "npm run lint:fix && npm run format:fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,mjs,ts,tsx,json,md,yml,Dockerfile,dockerfile}": "prettier --write",
    "src/**/*.{js,mjs}": "eslint --fix",
    "shared/**/*.{js,ts}": "eslint --fix",
    "web/**/*.{ts,tsx,js}": "npm run lint --workspace=web --fix"
  },
  "main": "src/index.js",
  "bin": {
    "svg-to-video": "src/index.js"
  },
  "workspaces": [
    "web"
  ]
}
